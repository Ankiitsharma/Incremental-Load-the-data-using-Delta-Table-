from delta import DeltaTable
from pyspark.sql import Window
from pyspark.sql.functions import dense_rank, desc,col

df = spark.read.table("ankit_cata.products_data.products")

#deduplicate the ids based on latest date

window_spec = Window.partitionBy('id').orderBy(col('update_date').desc())
df = df.withColumn('rnk', dense_rank().over(window_spec))\
    .filter(col('rnk')==1).drop("rnk")

df.display()
