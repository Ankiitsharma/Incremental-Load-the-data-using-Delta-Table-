if len(dbutils.fs.ls("/Volumes/ankit_cata/products_data/target_volume/data"))>0:
    #incremental load and backfill using s.update_date>=t.update_date
    target_obj = DeltaTable.forPath(spark, '/Volumes/ankit_cata/products_data/target_volume/data')
    target_obj.alias('trg').merge(df.alias('src'), 
                                "trg.id == src.id")\
                                    .whenMatchedUpdateAll(condition= "src.update_date>= trg.update_date")\
                                        .whenNotMatchedInsertAll()\
                                            .execute()
    print("update")
else:
    #initial Load
    df.write.format('delta')\
        .mode("overwrite")\
            .save("/Volumes/ankit_cata/products_data/target_volume/data")
    print("insert")


